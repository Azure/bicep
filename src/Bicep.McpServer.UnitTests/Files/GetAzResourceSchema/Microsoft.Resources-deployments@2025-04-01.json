      "const": "2025-04-01",
      "description": "The resource api version",
      "readOnly": true,
      "x-bicep-deploy-time-constant": true
    },
    "id": {
      "type": "string",
      "description": "The resource id",
      "readOnly": true,
      "x-bicep-deploy-time-constant": true
    },
    "identity": {
      "$ref": "#/$defs/DeploymentIdentity",
