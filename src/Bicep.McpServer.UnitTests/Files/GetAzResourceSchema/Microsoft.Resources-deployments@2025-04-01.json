{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Microsoft.Resources/deployments@2025-04-01",
  "description": "Bicep resource schema for Microsoft.Resources/deployments@2025-04-01",
  "x-bicep-resource-flags": "None",
