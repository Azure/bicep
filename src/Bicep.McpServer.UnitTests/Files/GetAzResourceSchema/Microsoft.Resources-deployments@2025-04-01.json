    "DeploymentPropertiesOrDeploymentPropertiesExtended": {
      "type": "object",
      "properties": {
        "correlationId": {
          "type": "string",
          "description": "The correlation ID of the deployment.",
          "readOnly": true
        },
        "debugSetting": {
          "$ref": "#/$defs/DebugSetting",
