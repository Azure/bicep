      "writeOnly": true
    },
    "location": {
      "type": "string",
      "description": "The location to store the deployment data."
    },
    "name": {
      "type": "string",
      "description": "The resource name",
      "x-bicep-deploy-time-constant": true,
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[-\\w\\._\\(\\)]+$"
    },
    "properties": {
      "$ref": "#/$defs/DeploymentPropertiesOrDeploymentPropertiesExtended",
      "description": "The deployment properties."
    },
    "tags": {
      "$ref": "#/$defs/DeploymentTags",
      "description": "Deployment tags"
    },
    "type": {
      "const": "Microsoft.Resources/deployments",
      "description": "The resource type",
      "readOnly": true,
      "x-bicep-deploy-time-constant": true
    }
  },
  "required": [
    "name",
    "properties"
  ],
  "$defs": {
