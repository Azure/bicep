{
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "devDependencies": {
    "@azure/bicep-rpc-client": "^0.2.1",
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/cross-spawn": "^6.0.6",
    "@types/eslint__js": "^9.14.0",
    "@types/uuid": "^11.0.0",
    "@vitest/eslint-plugin": "^1.6.23",
    "cross-env": "^10.1.0",
    "cross-spawn": "^7.0.6",
    "eslint": "^10.7.0",
    "eslint-plugin-notice": "^1.0.0",
    "prettier": "^3.9.6",
    "rimraf": "^6.1.3",
    "typescript": "~7.0.2",
    "typescript-eslint": "^8.65.0",
    "uuid": "^14.0.1",
    "vitest": "^4.1.10"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "test": "npm run check-types && vitest local/",
    "test:live:prod": "npm run check-types && cross-env TEST_ENVIRONMENT=prod vitest live/",
    "test:live:ff": "npm run check-types && cross-env TEST_ENVIRONMENT=fairfax vitest live/",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,ts,md}\""
  }
}
